ave}>\n          <div className=\"mb-4\">\n            <label className=\"block text-sm font-medium text-gray-700 mb-1\" htmlFor=\"edit-title\">\n              Title <span className=\"text-red-500\">*</span>\n            </label>\n            <input\n              id=\"edit-title\"\n              type=\"text\"\n              value={title}\n              onChange={(e) => {\n                setTitle(e.target.value);\n                if (e.target.value.trim()) setTitleError('');\n              }}\n              className={`w-full border rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 ${\n                titleError ? 'border-red-500' : 'border-gray-300'\n              }`}\n              disabled={saving}\n            />\n            {titleError && (\n              <p className=\"text-red-500 text-xs mt-1\">{titleError}</p>\n            )}\n          </div>\n\n          <div className=\"mb-4\">\n            <label className=\"block text-sm font-medium text-gray-700 mb-1\" htmlFor=\"edit-due-date\">\n              Due Date\n            </label>\n            <input\n              id=\"edit-due-date\"\n              type=\"date\"\n              value={dueDate}\n              onChange={(e) => setDueDate(e.target.value)}\n              className=\"w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500\"\n              disabled={saving}\n            />\n          </div>\n\n          <div className=\"mb-6\">\n            <label className=\"block text-sm font-medium text-gray-700 mb-1\" htmlFor=\"edit-category\">\n              Category\n            </label>\n            <input\n              id=\"edit-category\"\n              type=\"text\"\n              value={category}\n              onChange={(e) => setCategory(e.target.value)}\n              className=\"w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500\"\n              disabled={saving}\n            />\n          </div>\n\n          <div className=\"flex justify-end gap-3\">\n            <button\n              type=\"button\"\n              onClick={onCancel}\n              disabled={saving}\n              className=\"px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50 disabled:opacity-50 disabled:cursor-not-allowed focus:outline-none focus:ring-2 focus:ring-blue-500\"\n            >\n              Cancel\n            </button>\n            <button\n              type=\"submit\"\n              disabled={saving}\n              className=\"px-4 py-2 text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 disabled:bg-blue-300 disabled:cursor-not-allowed rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2\"\n            >\n              {saving ? 'Saving...' : 'Save'}\n            </button>\n          </div>\n        </form>\n      </div>\n    </div>\n  );\n};\n\nexport default EditModal;\n","structuredPatch":[],"originalFile":null,"userModified":false}}
{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_014qJrDM7Qx8258x4pknam2z","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01GfRVEVgcEPEpgS9pn8xtRj","name":"Write","input":{"file_path":"/Users/kajendran/.asdlc/repos/default/kaj-test-14/task-ui/src/components/TaskCard.tsx","content":"import React from 'react';\nimport type { Task } from '../types';\n\ninterface TaskCardProps {\n  task: Task;\n  onToggleComplete: (id: string, completed: boolean) => void;\n  onEdit: (task: Task) => void;\n  onDelete: (id: string) => void;\n}\n\nfunction isOverdue(dueDate: string | null): boolean {\n  if (!dueDate) return false;\n  // Compare date strings directly (YYYY-MM-DD) to avoid timezone issues.\n  // Get local today as YYYY-MM-DD.\n  const now = new Date();\n  const year = now.getFullYear();\n  const month = String(now.getMonth() + 1).padStart(2, '0');\n  const day = String(now.getDate()).padStart(2, '0');\n  const today = `${year}-${month}-${day}`;\n  return dueDate < today;\n}\n\nfunction formatDate(dateStr: string): string {\n  // Display date in local locale using date-only parsing (no timezone shift).\n  const [year, month, day] = dateStr.split('-').map(Number);\n  const date = new Date(year, month - 1, day);\n  return date.toLocaleDateString(undefined, { year: 'numeric', month: 'short', day: 'numeric' });\n}\n\nconst TaskCard: React.FC<TaskCardProps> = ({ task, onToggleComplete, onEdit, onDelete }) => {\n  const overdue = !task.completed && isOverdue(task.dueDate);\n\n  const handleDelete = () => {\n    if (window.confirm(`Are you sure you want to delete \"${task.title}\"?`)) {\n      onDelete(task.id);\n    }\n  };\n\n  return (\n    <div className=\"flex items-start gap-3 bg-white border border-gray-200 rounded-lg px-4 py-3 shadow-sm hover:shadow-md transition-shadow\">\n      {/* Completion checkbox */}\n      <input\n        type=\"checkbox\"\n        checked={task.completed}\n        onChange={(e) => onToggleComplete(task.id, e.target.checked)}\n        className=\"mt-1 h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500 cursor-pointer flex-shrink-0\"\n        aria-label={`Mark \"${task.title}\" as ${task.completed ? 'incomplete' : 'complete'}`}\n      />\n\n      {/* Task details */}\n      <div className=\"flex-1 min-w-0\">\n        <p\n          className={`text-sm font-medium break-words ${\n            task.completed ? 'line-through text-gray-400' : 'text-gray-800'\n          }`}\n        >\n          {task.title}\n        </p>\n\n        <div className=\"flex flex-wrap items-center gap-2 mt-1\">\n          {/* Category badge */}\n          {task.category && (\n            <span className=\"inline-block bg-blue-100 text-blue-800 text-xs font-medium px-2 py-0.5 rounded-full\">\n              {task.category}\n            </span>\n          )}\n\n          {/* Due date */}\n          {task.dueDate && (\n            <span\n              className={`text-xs ${\n                overdue ? 'text-red-600 font-semibold' : 'text-gray-500'\n              }`}\n            >\n              {overdue ? '⚠ Overdue: ' : 'Due: '}\n              {formatDate(task.dueDate)}\n            </span>\n          )}\n        </div>\n      </div>\n\n      {/* Action buttons */}\n      <div className=\"flex items-center gap-2 flex-shrink-0\">\n        <button\n          onClick={() => onEdit(task)}\n          className=\"text-xs text-blue-600 hover:text-blue-800 font-medium focus:outline-none focus:underline\"\n          aria-label={`Edit \"${task.title}\"`}\n        >\n          Edit\n        </button>\n        <button\n          onClick={handleDelete}\n          className=\"text-xs text-red-500 hover:text-red-700 font-medium focus:outline-none focus:underline\"\n          aria-label={`Delete \"${task.title}\"`}\n        >\n          Delete\n        </button>\n      </div>\n    </div>\n  );\n};\n\nexport default TaskCard;\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1448,"cache_read_input_tokens":31769,"cache_creation":{"ephemeral_5m_input_tokens":1448,"ephemeral_1h_input_tokens":0},"output_tokens":70,"service_tier":"standard","inference_geo":"global"},"context_management":null},"parent_tool_use_id":null,"session_id":"2f27ef23-9ff9-47c5-8737-d226c025c699","uuid":"1f927abd-ed65-42dd-89c0-21a73b876a94"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GfRVEVgcEPEpgS9pn8xtRj","type":"tool_result","content":"File created successfully at: /Users/kajendran/.asdlc/repos/default/kaj-test-14/task-ui/src/components/TaskCard.tsx"}]},"parent_tool_use_id":null,"session_id":"2f27ef23-9ff9-47c5-8737-d226c025c699","uuid":"77b80321-67a9-4218-9f4c-c16391c078b4","timestamp":"2026-04-23T09:57:32.898Z","tool_use_result":{"type":"create","filePath":"/Users/kajendran/.asdlc/repos/default/kaj-test-14/task-ui/src/components/TaskCard.tsx","content":"import React from 'react';\nimport type { Task } from '../types';\n\ninterface TaskCardProps {\n  task: Task;\n  onToggleComplete: (id: string, completed: boolean) => void;\n  onEdit: (task: Task) => void;\n  onDelete: (id: string) => void;\n}\n\nfunction isOverdue(dueDate: string | null): boolean {\n  if (!dueDate) return false;\n  // Compare date strings directly (YYYY-MM-DD) to avoid timezone issues.\n  // Get local today as YYYY-MM-DD.\n  const now = new Date();\n  const year = now.getFullYear();\n  const month = String(now.getMonth() + 1).padStart(2, '0');\n  const day = String(now.getDate()).padStart(2, '0');\n  const today = `${year}-${month}-${day}`;\n  return dueDate < today;\n}\n\nfunction formatDate(dateStr: string): string {\n  // Display date in local locale using date-only parsing (no timezone shift).\n  const [year, month, day] = dateStr.split('-').map(Number);\n  const date = new Date(year, month - 1, day);\n  return date.toLocaleDateString(undefined, { year: 'numeric', month: 'short', day: 'numeric' });\n}\n\nconst TaskCard: React.FC<TaskCardProps> = ({ task, onToggleComplete, onEdit, onDelete }) => {\n  const overdue = !task.completed && isOverdue(task.dueDate);\n\n  const handleDelete = () => {\n    if (window.confirm(`Are you sure you want to delete \"${task.title}\"?`)) {\n      onDelete(task.id);\n    }\n  };\n\n  return (\n    <div className=\"flex items-start gap-3 bg-white border border-gray-200 rounded-lg px-4 py-3 shadow-sm hover:shadow-md transition-shadow\">\n      {/* Completion checkbox */}\n      <input\n        type=\"checkbox\"\n        checked={task.completed}\n        onChange={(e) => onToggleComplete(task.id, e.target.checked)}\n        className=\"mt-1 h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500 cursor-pointer flex-shrink-0\"\n        aria-label={`Mark \"${task.title}\" as ${task.completed ? 'incomplete' : 'complete'}`}\n      />\n\n      {/* Task details */}\n      <div className=\"flex-1 min-w-0\">\n        <p\n          className={`text-sm font-medium break-words ${\n            task.completed ? 'line-through text-gray-400' : 'text-gray-800'\n          }`}\n        >\n          {task.title}\n        </p>\n\n        <div className=\"flex flex-wrap items-center gap-2 mt-1\">\n          {/* Category badge */}\n          {task.category && (\n            <span className=\"inline-block bg-blue-100 text-blue-800 text-xs font-medium px-2 py-0.5 rounded-full\">\n              {task.category}\n            </span>\n          )}\n\n          {/* Due date */}\n          {task.dueDate && (\n            <span\n              className={`text-xs ${\n                overdue ? 'text-red-600 font-semibold' : 'text-gray-500'\n              }`}\n            >\n              {overdue ? '⚠ Overdue: ' : 'Due: '}\n              {formatDate(task.dueDate)}\n            </span>\n          )}\n        </div>\n      </div>\n\n      {/* Action buttons */}\n      <div className=\"flex items-center gap-2 flex-shrink-0\">\n        <button\n          onClick={() => onEdit(task)}\n          className=\"text-xs text-blue-600 hover:text-blue-800 font-medium focus:outline-none focus:underline\"\n          aria-label={`Edit \"${task.title}\"`}\n        >\n          Edit\n        </button>\n        <button\n          onClick={handleDelete}\n          className=\"text-xs text-red-500 hover:text-red-700 font-medium focus:outline-none focus:underline\"\n          aria-label={`Delete \"${task.title}\"`}\n        >\n          Delete\n        </button>\n      </div>\n    </div>\n  );\n};\n\nexport default TaskCard;\n","structuredPatch":[],"originalFile":null,"userModified":false}}

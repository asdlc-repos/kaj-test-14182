{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0143jKmNkftYkP2vbe1o773Y","type":"tool_result","content":"1\timport React, { useState, useEffect, useCallback } from 'react';\n2\timport type { Task, TaskInput, CompletionFilter } from './types';\n3\timport {\n4\t  fetchTasks,\n5\t  createTask,\n6\t  updateTask,\n7\t  deleteTask,\n8\t  toggleTaskComplete,\n9\t  fetchCategories,\n10\t} from './api';\n11\timport FilterBar from './components/FilterBar';\n12\timport AddTaskForm from './components/AddTaskForm';\n13\timport TaskCard from './components/TaskCard';\n14\timport EditModal from './components/EditModal';\n15\timport ErrorBanner from './components/ErrorBanner';\n16\t\n17\tconst App: React.FC = () => {\n18\t  const [tasks, setTasks] = useState<Task[]>([]);\n19\t  const [categories, setCategories] = useState<string[]>([]);\n20\t  const [selectedCategory, setSelectedCategory] = useState<string>('');\n21\t  const [completionFilter, setCompletionFilter] = useState<CompletionFilter>('all');\n22\t  const [editingTask, setEditingTask] = useState<Task | null>(null);\n23\t  const [error, setError] = useState<string | null>(null);\n24\t  const [loading, setLoading] = useState(false);\n25\t\n26\t  const loadCategories = useCallback(async () => {\n27\t    try {\n28\t      const cats = await fetchCategories();\n29\t      setCategories(cats);\n30\t    } catch {\n31\t      // Non-critical; don't surface category fetch errors separately\n32\t    }\n33\t  }, []);\n34\t\n35\t  const loadTasks = useCallback(async () => {\n36\t    setLoading(true);\n37\t    try {\n38\t      const params: { category?: string; completed?: boolean } = {};\n39\t      if (selectedCategory) params.category = selectedCategory;\n40\t      if (completionFilter === 'complete') params.completed = true;\n41\t      if (completionFilter === 'incomplete') params.completed = false;\n42\t      const data = await fetchTasks(params);\n43\t      setTasks(data);\n44\t    } catch (err) {\n45\t      setError('Failed to load tasks. Please try again.');\n46\t      console.error(err);\n47\t    } finally {\n48\t      setLoading(false);\n49\t    }\n50\t  }, [selectedCategory, completionFilter]);\n51\t\n52\t  // Initial load\n53\t  useEffect(() => {\n54\t    loadCategories();\n55\t  }, [loadCategories]);\n56\t\n57\t  useEffect(() => {\n58\t    loadTasks();\n59\t  }, [loadTasks]);\n60\t\n61\t  const handleAddTask = async (input: TaskInput) => {\n62\t    try {\n63\t      await createTask(input);\n64\t      await Promise.all([loadTasks(), loadCategories()]);\n65\t    } catch (err) {\n66\t      setError('Failed to create task. Please try again.');\n67\t      throw err; // Re-throw so AddTaskForm can reset its submitting state\n68\t    }\n69\t  };\n70\t\n71\t  const handleToggleComplete = async (id: string, completed: boolean) => {\n72\t    try {\n73\t      await toggleTaskComplete(id, completed);\n74\t      await loadTasks();\n75\t    } catch {\n76\t      setError('Failed to update task completion. Please try again.');\n77\t    }\n78\t  };\n79\t\n80\t  const handleEditSave = async (id: string, input: TaskInput) => {\n81\t    try {\n82\t      await updateTask(id, input);\n83\t      setEditingTask(null);\n84\t      await Promise.all([loadTasks(), loadCategories()]);\n85\t    } catch (err) {\n86\t      setError('Failed to update task. Please try again.');\n87\t      throw err;\n88\t    }\n89\t  };\n90\t\n91\t  const handleDelete = async (id: string) => {\n92\t    try {\n93\t      await deleteTask(id);\n94\t      await loadTasks();\n95\t    } catch {\n96\t      setError('Failed to delete task. Please try again.');\n97\t    }\n98\t  };\n99\t\n100\t  return (\n101\t    <div className=\"min-h-screen bg-gray-50\">\n102\t      {/* Header */}\n103\t      <header className=\"bg-blue-600 shadow-sm\">\n104\t        <div className=\"max-w-3xl mx-auto px-4 py-4\">\n105\t          <h1 className=\"text-2xl font-bold text-white tracking-tight\">My Tasks</h1>\n106\t        </div>\n107\t      </header>\n108\t\n109\t      {/* Main content */}\n110\t      <main className=\"max-w-3xl mx-auto px-4 py-6\">\n111\t        {/* Error banner */}\n112\t        {error && (\n113\t          <ErrorBanner message={error} onDismiss={() => setError(null)} />\n114\t        )}\n115\t\n116\t        {/* Add Task Form */}\n117\t        <AddTaskForm onAdd={handleAddTask} />\n118\t\n119\t        {/* Filter Bar */}\n120\t        <FilterBar\n121\t          categories={categories}\n122\t          selectedCategory={selectedCategory}\n123\t          completionFilter={completionFilter}\n124\t          onCategoryChange={setSelectedCategory}\n125\t          onCompletionChange={setCompletionFilter}\n126\t        />\n127\t\n128\t        {/* Task List */}\n129\t        {loading ? (\n130\t          <div className=\"text-center py-12 text-gray-500 text-sm\">Loading tasks...</div>\n131\t        ) : tasks.length === 0 ? (\n132\t          <div className=\"text-center py-12 text-gray-400\">\n133\t            <p className=\"text-lg font-medium\">No tasks found</p>\n134\t            <p className=\"text-sm mt-1\">\n135\t              {selectedCategory || completionFilter !== 'all'\n136\t                ? 'Try adjusting your filters.'\n137\t                : 'Add a task above to get started.'}\n138\t            </p>\n139\t          </div>\n140\t        ) : (\n141\t          <div className=\"flex flex-col gap-2\">\n142\t            {tasks.map((task) => (\n143\t              <TaskCard\n144\t                key={task.id}\n145\t                task={task}\n146\t                onToggleComplete={handleToggleComplete}\n147\t                onEdit={setEditingTask}\n148\t                onDelete={handleDelete}\n149\t              />\n150\t            ))}\n151\t          </div>\n152\t        )}\n153\t      </main>\n154\t\n155\t      {/* Edit Modal */}\n156\t      {editingTask && (\n157\t        <EditModal\n158\t          task={editingTask}\n159\t          onSave={handleEditSave}\n160\t          onCancel={() => setEditingTask(null)}\n161\t        />\n162\t      )}\n163\t    </div>\n164\t  );\n165\t};\n166\t\n167\texport default App;\n168\t"}]},"parent_tool_use_id":null,"session_id":"2f27ef23-9ff9-47c5-8737-d226c025c699","uuid":"53a1ab4a-e7b0-4ee5-a10e-c42102f817e8","timestamp":"2026-04-23T09:58:28.819Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/kajendran/.asdlc/repos/default/kaj-test-14/task-ui/src/App.tsx","content":"import React, { useState, useEffect, useCallback } from 'react';\nimport type { Task, TaskInput, CompletionFilter } from './types';\nimport {\n  fetchTasks,\n  createTask,\n  updateTask,\n  deleteTask,\n  toggleTaskComplete,\n  fetchCategories,\n} from './api';\nimport FilterBar from './components/FilterBar';\nimport AddTaskForm from './components/AddTaskForm';\nimport TaskCard from './components/TaskCard';\nimport EditModal from './components/EditModal';\nimport ErrorBanner from './components/ErrorBanner';\n\nconst App: React.FC = () => {\n  const [tasks, setTasks] = useState<Task[]>([]);\n  const [categories, setCategories] = useState<string[]>([]);\n  const [selectedCategory, setSelectedCategory] = useState<string>('');\n  const [completionFilter, setCompletionFilter] = useState<CompletionFilter>('all');\n  const [editingTask, setEditingTask] = useState<Task | null>(null);\n  const [error, setError] = useState<string | null>(null);\n  const [loading, setLoading] = useState(false);\n\n  const loadCategories = useCallback(async () => {\n    try {\n      const cats = await fetchCategories();\n      setCategories(cats);\n    } catch {\n      // Non-critical; don't surface category fetch errors separately\n    }\n  }, []);\n\n  const loadTasks = useCallback(async () => {\n    setLoading(true);\n    try {\n      const params: { category?: string; completed?: boolean } = {};\n      if (selectedCategory) params.category = selectedCategory;\n      if (completionFilter === 'complete') params.completed = true;\n      if (completionFilter === 'incomplete') params.completed = false;\n      const data = await fetchTasks(params);\n      setTasks(data);\n    } catch (err) {\n      setError('Failed to load tasks. Please try again.');\n      console.error(err);\n    } finally {\n      setLoading(false);\n    }\n  }, [selectedCategory, completionFilter]);\n\n  // Initial load\n  useEffect(() => {\n    loadCategories();\n  }, [loadCategories]);\n\n  useEffect(() => {\n    loadTasks();\n  }, [loadTasks]);\n\n  const handleAddTask = async (input: TaskInput) => {\n    try {\n      await createTask(input);\n      await Promise.all([loadTasks(), loadCategories()]);\n    } catch (err) {\n      setError('Failed to create task. Please try again.');\n      throw err; // Re-throw so AddTaskForm can reset its submitting state\n    }\n  };\n\n  const handleToggleComplete = async (id: string, completed: boolean) => {\n    try {\n      await toggleTaskComplete(id, completed);\n      await loadTasks();\n    } catch {\n      setError('Failed to update task completion. Please try again.');\n    }\n  };\n\n  const handleEditSave = async (id: string, input: TaskInput) => {\n    try {\n      await updateTask(id, input);\n      setEditingTask(null);\n      await Promise.all([loadTasks(), loadCategories()]);\n    } catch (err) {\n      setError('Failed to update task. Please try again.');\n      throw err;\n    }\n  };\n\n  const handleDelete = async (id: string) => {\n    try {\n      await deleteTask(id);\n      await loadTasks();\n    } catch {\n      setError('Failed to delete task. Please try again.');\n    }\n  };\n\n  return (\n    <div className=\"min-h-screen bg-gray-50\">\n      {/* Header */}\n      <header className=\"bg-blue-600 shadow-sm\">\n        <div className=\"max-w-3xl mx-auto px-4 py-4\">\n          <h1 className=\"text-2xl font-bold text-white tracking-tight\">My Tasks</h1>\n        </div>\n      </header>\n\n      {/* Main content */}\n      <main className=\"max-w-3xl mx-auto px-4 py-6\">\n        {/* Error banner */}\n        {error && (\n          <ErrorBanner message={error} onDismiss={() => setError(null)} />\n        )}\n\n        {/* Add Task Form */}\n        <AddTaskForm onAdd={handleAddTask} />\n\n        {/* Filter Bar */}\n        <FilterBar\n          categories={categories}\n          selectedCategory={selectedCategory}\n          completionFilter={completionFilter}\n          onCategoryChange={setSelectedCategory}\n          onCompletionChange={setCompletionFilter}\n        />\n\n        {/* Task List */}\n        {loading ? (\n          <div className=\"text-center py-12 text-gray-500 text-sm\">Loading tasks...</div>\n        ) : tasks.length === 0 ? (\n          <div className=\"text-center py-12 text-gray-400\">\n            <p className=\"text-lg font-medium\">No tasks found</p>\n            <p className=\"text-sm mt-1\">\n              {selectedCategory || completionFilter !== 'all'\n                ? 'Try adjusting your filters.'\n                : 'Add a task above to get started.'}\n            </p>\n          </div>\n        ) : (\n          <div className=\"flex flex-col gap-2\">\n            {tasks.map((task) => (\n              <TaskCard\n                key={task.id}\n                task={task}\n                onToggleComplete={handleToggleComplete}\n                onEdit={setEditingTask}\n                onDelete={handleDelete}\n              />\n            ))}\n          </div>\n        )}\n      </main>\n\n      {/* Edit Modal */}\n      {editingTask && (\n        <EditModal\n          task={editingTask}\n          onSave={handleEditSave}\n          onCancel={() => setEditingTask(null)}\n        />\n      )}\n    </div>\n  );\n};\n\nexport default App;\n","numLines":168,"startLine":1,"totalLines":168}}}
